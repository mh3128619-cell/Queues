customers = ["Client_A", "Client_B", "Client_C", "Client_D"]
print(f"Queue at the beginning of the day: {customers}")

finished = customers.pop(0)
print(f"✅ Client {finished} finished and left. Current queue: {customers}")

customers.append("Client_E")
print(f"➕ Client Client_E joined the queue. Current queue: {customers}")

next_client = customers.pop(0)
print(f"🔔 Employee called: {next_client}")

print(f"🏁 Remaining queue at the end: {customers}")
